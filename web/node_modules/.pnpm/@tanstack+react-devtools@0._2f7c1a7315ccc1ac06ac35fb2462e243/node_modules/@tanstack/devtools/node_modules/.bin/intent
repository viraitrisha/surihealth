else
  export NODE_PATH="/mnt/c/Users/virai/surihealth/web/node_modules/.pnpm/@tanstack+devtools@0.12.5_csstype@3.2.3_solid-js@1.9.13/node_modules/@tanstack/devtools/node_modules:/mnt/c/Users/virai/surihealth/web/node_modules/.pnpm/@tanstack+devtools@0.12.5_csstype@3.2.3_solid-js@1.9.13/node_modules:/mnt/c/Users/virai/surihealth/web/node_modules/.pnpm/node_modules:$NODE_PATH"
fi
if [ -n "$exe" ] && [ -x "$basedir/node.exe" ]; then
  exec "$basedir/node.exe"  "$basedir_win/../../bin/intent.js" "$@"
elif [ -x "$basedir/node" ]; then
  exec "$basedir/node"  "$basedir/../../bin/intent.js" "$@"
elif command -v node >/dev/null 2>&1; then
  exec node  "$basedir/../../bin/intent.js" "$@"
elif [ -n "$exe" ] && command -v node.exe >/dev/null 2>&1; then
